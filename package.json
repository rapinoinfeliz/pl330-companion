{
  "name": "pl330-companion",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "pnpm --parallel --filter @pl330/web --filter @pl330/worker dev",
    "build": "pnpm --filter @pl330/shared build && pnpm --filter @pl330/web build && pnpm --filter @pl330/worker build",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @pl330/web test:e2e",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:migrate:local": "wrangler d1 migrations apply pl330-companion --local",
    "db:migrate:remote": "wrangler d1 migrations apply pl330-companion --remote",
    "import:eibi:local": "tsx scripts/import-eibi.ts",
    "deploy": "pnpm build && wrangler deploy"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.24.0"
  }
}
